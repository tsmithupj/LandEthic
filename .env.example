# ─── LandEthic.io Environment Variables ───────────────────────────────────────
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to git.

# ── Auth (Clerk) ─────────────────────────────────────────────────────────────
# Create a free account at https://clerk.com, then:
#   1. Create a new application
#   2. Enable Google + Email sign-in
#   3. Copy keys from Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk routing — leave these as-is unless you move the auth pages
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── AI ───────────────────────────────────────────────────────────────────────
# Anthropic Claude API — used for property analysis and plan generation
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Mapping ──────────────────────────────────────────────────────────────────
# Mapbox — satellite imagery tiles and static map images
# Get your key at: https://account.mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Parcel Data ───────────────────────────────────────────────────────────────
# Regrid — property parcel boundary data (auto-detects property lines from address)
# Get your key at: https://regrid.com/api
REGRID_API_KEY=

# ── Payments ─────────────────────────────────────────────────────────────────
# Stripe — subscription billing
# Get your keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
